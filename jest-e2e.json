{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "testTimeout": 10000,
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "diagnostics": false }]
  },
  "moduleNameMapper": {
    "^@golevelup/nestjs-rabbitmq$": "<rootDir>/libs/rabbitmq/src",
    "^@golevelup/nestjs-discovery$": "<rootDir>/libs/discovery/src"
  },
  "setupFilesAfterEnv": [
    "<rootDir>/jest.setup.js"
  ]
}
